# 와벨리 앱 환경변수 예시 — 복사해서 .env 로 만들고 실제 값 채우기.
# EXPO_PUBLIC_* 는 클라이언트 번들에 포함되는 "공개" 키만. (anon/공개 식별자)
# service_role 키·PortOne API secret 등 "비밀"은 .env 가 아니라 Supabase Edge Function 환경변수에 둠(SETUP.md 참고).

# Supabase (Dashboard > Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 네이버 (공개 client id)
EXPO_PUBLIC_NAVER_LOGIN_CLIENT_ID=your-naver-login-client-id
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=your-naver-map-client-id

# PortOne 결제 (공개 store/channel 식별자)
EXPO_PUBLIC_PORTONE_STORE_ID=your-portone-store-id
EXPO_PUBLIC_PORTONE_CHANNEL_KEY=your-portone-channel-key
EXPO_PUBLIC_PORTONE_BILLING_CHANNEL_KEY=your-portone-billing-channel-key
