{
  "expo": {
    "name": "와벨리",
    "slug": "wavely",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wavely",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.wavely.app",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "내 주변 매장 검색과 방문 인증을 위해 위치 정보를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "프로필 사진·게시물 사진/영상 업로드를 위해 사진 보관함에 접근합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wavely.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#7A2BC4",
        "foregroundImage": "./assets/images/wavely-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/wavely-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#7A2BC4",
          "icon": "./assets/images/android-icon-monochrome.png"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#7A2BC4",
          "image": "./assets/images/wavely-logo.png",
          "imageWidth": 150,
          "resizeMode": "contain"
        }
      ],
      "expo-video",
      "expo-apple-authentication",
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "53vvza8ax4"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://repository.map.naver.com/archive/maven"
            ]
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "523c48d5-ce08-42a5-98bd-921c9e7fa562"
      }
    }
  }
}
